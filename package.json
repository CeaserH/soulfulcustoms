{
  "name": "soulful-customs",
  "version": "1.0.0",
  "description": "Photography printing website for Soulful Customs",
  "source": "src/index.html",
  "scripts": {
    "start": "parcel src/index.html --port 1234",
    "dev": "parcel src/index.html --port 1234",
    "build": "parcel build src/index.html --dist-dir dist",
    "postbuild": "node scripts/create-spa-fallbacks.js",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@parcel/transformer-sass": "^2.12.0",
    "buffer": "^6.0.3",
    "gh-pages": "^6.3.0",
    "parcel": "^2.12.0"
  }
}
